#!/usr/bin/env bash

if [[ "${GLOBAL:-}" != 1 ]]; then
	source ./Shared/secrets
	source ./Shared/dotfiles
	source ./desktop/flatpak
fi

sudo pacman -S --noconfirm --needed git

personal_repos=(Personal setup-extras)
personal_repos_dest=("$PWD"/.personal "$PWD"/extras)

for repo_index in ${!personal_repos[@]}; do
	if ! [[ -d "${personal_repos_dest[$repo_index]}" ]]; then
		git clone --depth 1 \
			https://"$GIT_TOKEN"@github.com/"$GIT_USER"/"${personal_repos[$repo_index]}".git \
			"${personal_repos_dest[$repo_index]}"
	fi
done

install_dotfile "$PWD"/.personal
if ! grep -ie "\"library_path\":.*$HOME/Books" "$HOME"/.config/calibre/global.py.json; then
	sed -i --follow-symlinks "s|\"library_path\": *\"[^\"]*\"|\"library_path\": \"$HOME/Books\"|" "$HOME/.config/calibre/global.py.json"
fi
if ! grep -ie "\"database_path\":.*$HOME/Books/library1.db" "$HOME"/.config/calibre/global.py.json; then
	sed -i --follow-symlinks "s|\"database_path\": *\"[^\"]*\"|\"database_path\": \"$HOME/Books/library1.db\"|" "$HOME/.config/calibre/global.py.json"
fi

apps=(
	app.zen_browser.zen
	org.mozilla.firefox
	org.chromium.Chromium
	md.obsidian.Obsidian
	com.calibre_ebook.calibre
)

zen_browser_override=(
	--filesystem=home/.zen
)

firefox_override=(
	--filesystem=home/.mozilla
)

calibre_override=(
	--filesystem=xdg-config/calibre
	--filesystem=home/Books
)

for app_id in "${!apps[@]}"; do
	flatpak install \
		--user \
		--noninteractive \
		--assumeyes \
		"${apps[$app_id]}"
done

flatpak override --user "${zen_browser_override[@]}" app.zen_browser.zen
flatpak override --user "${firefox_override[@]}" org.mozilla.firefox
flatpak override --user "${calibre_override[@]}" com.calibre_ebook.calibre
